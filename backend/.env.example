# FundAI Backend Environment Variables
# Copy this file to .env and fill in your values

# Flask secret key for JWT signing (use a strong random string)
SECRET_KEY=your-super-secret-key-change-this

# Database URL (default: SQLite, use PostgreSQL for production)
DATABASE_URL=sqlite:///fundai.db
# DATABASE_URL=postgresql://user:password@localhost:5432/fundai

# Debug mode (set to false in production)
FLASK_DEBUG=true

# Frontend URL for CORS (set to your production domain)
FRONTEND_URL=http://localhost:5173

# Firebase (set GOOGLE_APPLICATION_CREDENTIALS for production)
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/firebase-service-account.json
